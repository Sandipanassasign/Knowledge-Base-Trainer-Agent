# ── Qdrant (Vector Database) ──
# Option A: Qdrant Cloud (FREE — No Docker needed!)
#   1. Sign up at https://cloud.qdrant.io (free, no credit card)
#   2. Create a cluster → copy the URL and API key below
# Option B: Local Docker (if Docker is available)
#   docker run -p 6333:6333 qdrant/qdrant
#   Then use: QDRANT_URL=http://localhost:6333

QDRANT_URL=https://your-cluster-id.cloud.qdrant.io:6333
QDRANT_API_KEY=your-qdrant-api-key-here
QDRANT_COLLECTION=defect_knowledge_base

# ── OpenAI ──
OPENAI_API_KEY=sk-your-key-here
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.2

# ── Embeddings ──
EMBEDDING_MODEL=all-MiniLM-L6-v2
